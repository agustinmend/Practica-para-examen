{
  "name": "examen-web-isw-233",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000, 5500],
  "portsAttributes": {
    "3000": { "label": "Vite dev server", "onAutoForward": "notify" },
    "5500": { "label": "Live Server", "onAutoForward": "silent" }
  },
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "vitest.explorer",
        "ms-vscode.live-server",
        "ritwickdey.LiveServer",
        "ms-vscode.vscode-typescript-next",
        "andrejunges.Handlebars",
        "chuckjonas.handlebars-eslint",
        "formulahendry.auto-rename-tag",
        "formulahendry.auto-close-tag",
        "ecmel.vscode-html-css",
        "Zignd.html-css-class-completion",
        "pranaygp.vscode-css-peek",
        "naumovs.color-highlight"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "eslint.validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact"
        ],
        "liveServer.settings.port": 5500,
        "liveServer.settings.donotShowInfoMsg": true,

        "html.autoClosingTags": true,
        "html.completion.attributeDefaultValue": "doublequotes",
        "html.suggest.html5": true,
        "html.validate.scripts": true,
        "html.validate.styles": true,
        "css.completion.completePropertyWithSemicolon": true,
        "css.completion.triggerPropertyValueCompletion": true,
        "css.validate": true,
        "emmet.includeLanguages": {
          "handlebars": "html"
        },
        "emmet.triggerExpansionOnTab": true,
        "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[handlebars]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

        "chat.disableAIFeatures": false,
        "chat.commandCenter.enabled": false,
        "chat.agent.enabled": false,
        "chat.mcp.enabled": false,
        "chat.tools.autoApprove": false,
        "chat.experimental.variables": false,
        "chat.experimental.offerSetup": false,

        "github.copilot.enable": {
          "*": false,
          "plaintext": false,
          "markdown": false,
          "yaml": false,
          "env": false,
          "javascript": false,
          "typescript": false,
          "html": false,
          "css": false,
          "handlebars": false
        },
        "github.copilot.editor.enableAutoCompletions": false,
        "github.copilot.editor.enableInlineCompletions": false,
        "github.copilot.editor.enableCodeActions": false,
        "github.copilot.chat.editor.enableCodeActions": false,
        "github.copilot.chat.codesearch.enabled": false,
        "github.copilot.chat.agent.enabled": false,
        "github.copilot.chat.edits.enabled": false,
        "github.copilot.nextEditSuggestions.enabled": false,
        "github.copilot.advanced": {
          "inlineSuggestCount": 1,
          "listCount": 3
        },

        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false,
        "telemetry.telemetryLevel": "off"
      }
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development"
  }
}
